{
  "__inputs": [
    {
      "name": "DS_INFLUXDB",
      "label": "InfluxDB",
      "description": "Home Assistant InfluxDB (database: homeassistant)",
      "type": "datasource",
      "pluginId": "influxdb",
      "pluginName": "InfluxDB"
    }
  ],
  "__requires": [
    {
      "type": "datasource",
      "id": "influxdb",
      "name": "InfluxDB",
      "version": "1.0.0"
    },
    {
      "type": "panel",
      "id": "timeseries",
      "name": "Time series",
      "version": ""
    },
    {
      "type": "panel",
      "id": "stat",
      "name": "Stat",
      "version": ""
    }
  ],
  "annotations": {
    "list": []
  },
  "editable": true,
  "graphTooltip": 1,
  "refresh": "1m",
  "schemaVersion": 39,
  "tags": [
    "servers",
    "server-monitor"
  ],
  "time": {
    "from": "now-24h",
    "to": "now"
  },
  "timepicker": {},
  "title": "Servers",
  "templating": {
    "list": [
      {
        "name": "host",
        "label": "Host",
        "type": "custom",
        "multi": true,
        "includeAll": true,
        "allValue": ".*",
        "query": "plex_luthor,moxxy_proxxy,truenasty,long_john_silver",
        "current": {
          "text": [
            "All"
          ],
          "value": [
            "$__all"
          ]
        },
        "options": [
          {
            "text": "All",
            "value": "$__all",
            "selected": true
          },
          {
            "text": "plex_luthor",
            "value": "plex_luthor",
            "selected": false
          },
          {
            "text": "moxxy_proxxy",
            "value": "moxxy_proxxy",
            "selected": false
          },
          {
            "text": "truenasty",
            "value": "truenasty",
            "selected": false
          },
          {
            "text": "long_john_silver",
            "value": "long_john_silver",
            "selected": false
          }
        ]
      }
    ]
  },
  "panels": [
    {
      "type": "row",
      "title": "Temperatures",
      "collapsed": false,
      "gridPos": {
        "h": 1,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 2,
      "panels": []
    },
    {
      "type": "timeseries",
      "title": "CPU temperature",
      "datasource": {
        "type": "influxdb",
        "uid": "${DS_INFLUXDB}"
      },
      "gridPos": {
        "h": 8,
        "w": 8,
        "x": 0,
        "y": 1
      },
      "id": 3,
      "fieldConfig": {
        "defaults": {
          "unit": "celsius",
          "color": {
            "mode": "palette-classic"
          },
          "custom": {
            "drawStyle": "line",
            "lineWidth": 2,
            "fillOpacity": 8,
            "showPoints": "never",
            "spanNulls": true
          },
          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              },
              {
                "color": "yellow",
                "value": 65
              },
              {
                "color": "red",
                "value": 80
              }
            ]
          }
        },
        "overrides": []
      },
      "options": {
        "legend": {
          "displayMode": "table",
          "placement": "bottom",
          "calcs": [
            "lastNotNull",
            "max"
          ]
        },
        "tooltip": {
          "mode": "multi",
          "sort": "desc"
        }
      },
      "targets": [
        {
          "datasource": {
            "type": "influxdb",
            "uid": "${DS_INFLUXDB}"
          },
          "refId": "A",
          "rawQuery": true,
          "resultFormat": "time_series",
          "alias": "$tag_entity_id",
          "query": "SELECT mean(\"value\") FROM \"°C\" WHERE (\"entity_id\" =~ /^($host)_cpu.*temperature$/) AND $timeFilter GROUP BY time($__interval), \"entity_id\" fill(null)"
        }
      ]
    },
